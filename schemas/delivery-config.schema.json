{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wefter.dev/schemas/delivery-config.schema.json",
  "type": "object",
  "required": ["version", "workflowName", "releaseId", "deliverablesDocument", "sourceDocs", "runArtifactsRoot", "versionedArtifacts", "defaultDeliveryUnitId", "defaultPlanAuditPassesPerLens", "gatePolicy"],
  "properties": {
    "version": { "const": 1 },
    "workflowName": { "const": "delivery-implementation" },
    "releaseId": { "type": "string", "minLength": 1 },
    "deliverablesDocument": { "$ref": "#/$defs/relativePath" },
    "sourceDocs": {
      "type": "object",
      "required": ["include", "exclude"],
      "properties": {
        "include": { "type": "array", "items": { "$ref": "#/$defs/relativeGlob" } },
        "exclude": { "type": "array", "items": { "$ref": "#/$defs/relativeGlob" } }
      },
      "additionalProperties": false
    },
    "runArtifactsRoot": { "$ref": "#/$defs/relativePath" },
    "versionedArtifacts": {
      "type": "object",
      "required": ["executionRoot", "decisionLogRoot"],
      "properties": {
        "executionRoot": { "$ref": "#/$defs/relativePath" },
        "decisionLogRoot": { "$ref": "#/$defs/relativePath" }
      },
      "additionalProperties": false
    },
    "defaultDeliveryUnitId": { "type": "string", "minLength": 1 },
    "defaultPlanAuditPassesPerLens": { "type": "integer", "minimum": 1 },
    "gatePolicy": {
      "type": "object",
      "required": ["mode", "structuralDeliveryUnits", "alwaysPauseOn"],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "structuralDeliveryUnits": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "alwaysPauseOn": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?![\\/])(?!.*(?:^|[\\/])\\.\\.(?:[\\/]|$))[^\\r\\n]+$"
    },
    "relativeGlob": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?![\\/])(?!~)(?!.*(?:^|[\\/])\\.\\.(?:[\\/]|$))[^\\r\\n]+$"
    }
  }
}
